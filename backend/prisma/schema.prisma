generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  login            String   @unique
  createdAt        DateTime @default(now())
  roleId           Int?      @map("role_id")

  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret   String?

  role             Role?     @relation(fields: [roleId], references: [id])
  emailInfo        UserEmail?
  passwordInfo     UserPassword?
  objects          FireObject[]
  auditLogs        AuditLog[]

  @@map("User")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  users User[]

  @@map("Role")
}

model UserEmail {
  id     Int    @id @default(autoincrement())
  userId Int    @unique @map("user_id")
  email  String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserEmail")
}

model UserPassword {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserPassword")
}

model FireObject {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  createdAt DateTime @default(now())

  latitude  Float?
  longitude Float?

  userId      Int @map("user_id")
  typeId      Int @map("type_id")
  riskLevelId Int @map("risk_level_id")

  user      User       @relation(fields: [userId], references: [id])
  type      ObjectType @relation(fields: [typeId], references: [id])
  riskLevel RiskLevel  @relation(fields: [riskLevelId], references: [id])

  @@map("FireObject")
}

model ObjectType {
  id   Int    @id @default(autoincrement())
  name String @unique

  objects FireObject[]

  @@map("ObjectType")
}

model RiskLevel {
  id       Int    @id @default(autoincrement())
  code     String @unique
  name     String
  priority Int

  objects FireObject[]

  @@map("RiskLevel")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  details   String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("AuditLog")
}